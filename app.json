{
  "expo": {
    "name": "SlayCal",
    "description": "SlayCal is an AI-powered calorie tracker that helps you track your calories and improve your health.",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "slaycalai",
    "platforms": ["ios", "android"],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "owner": "mirrorbitai",
    "slug": "slaycalai",
    "android": {
      "package": "com.slaycal.android",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo.png",
        "backgroundImage": "./assets/images/logo.png",
        "monochromeImage": "./assets/images/logo.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.slaycal.ios",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "SlayCal uses your camera to scan and identify meals.",
        "NSCameraUsageDescription": "SlayCal uses your camera to scan and identify meals.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-localization",
      "./plugins/withAllowHttp",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "This app uses your camera to scan and identify meals.",
          "enableMicrophonePermission": false
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "SlayCal uses your camera to scan and identify meals.",
          "cameraPermission": "SlayCal uses your camera to scan and identify meals."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-dev-client"
    ],

    "extra": {
      "eas": {
        "projectId": "89379433-4b00-4065-b017-2977411a7be3"
      }
    }
  }
}
