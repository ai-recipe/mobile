{
  "expo": {
    "name": "myapp",
    "slug": "myapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "myapp",
    "platforms": ["ios", "android"],
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "appleTeamId": "MZC4RF3T88",
      "bundleIdentifier": "com.myapp",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Uygulama, yemek tarifleri oluşturmak için seçtiğiniz malzemelerin fotoğraflarına erişir.",
        "NSCameraUsageDescription": "This app uses your camera to scan and identify meals.",
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSAllowsLocalNetworking": true
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/logo.png",
        "backgroundImage": "./assets/images/logo.png",
        "monochromeImage": "./assets/images/logo.png"
      },
      "package": "com.myapp",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-localization",
      "./plugins/withAllowHttp",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "This app uses your camera to scan and identify meals.",
          "enableMicrophonePermission": false
        }
      ],
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo.png",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Uygulama, tarif oluşturmak için galerinize erişim ister.",
          "cameraPermission": "Uygulama, malzemeleri taramak için kameranızı kullanır."
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-dev-client"
    ],
    "extra": {
      "eas": {
        "projectId": "0af9548a-c546-434a-8e8f-74b6717f880a"
      }
    },
    "owner": "myapp",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/0af9548a-c546-434a-8e8f-74b6717f880a"
    }
  }
}
